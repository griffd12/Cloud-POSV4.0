# Cloud POS - Local Failover Server Configuration
# Copy this file to .env and fill in values

# Cloud connection
LFS_CLOUD_URL=https://7c25787c-567d-4d98-8151-1125794025a5-00-o90cqt9u859u.spock.replit.dev/
LFS_API_KEY=lfs_240aec31d6474416ca015553321e0e9ac92ee4c5440310b39c3b5104f6da33b6
LFS_PROPERTY_ID=b0c038b1-5c55-4c63-85fe-5ea9dc64a767

# Server ports
PORT=3001
LFS_ADMIN_PORT=3002

# Database
DB_MODE=local
SQLITE_PATH=./data/pos-local.db

# Sync interval (milliseconds, default 60000 = 1 minute)
LFS_SYNC_INTERVAL_MS=60000

# Auto-update (set to false to disable)
LFS_AUTO_UPDATE=true
LFS_UPDATE_CHECK_INTERVAL_MS=3600000

# Logging
LFS_LOG_LEVEL=info
